# Shared release metadata
HERMES_RELEASE_BASE_URL=https://downloads.example.com/hermes-companion
HERMES_RELEASE_NOTES=Release notes for this build

# Tauri updater signing
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
TAURI_UPDATER_PUBKEY=
TAURI_UPDATER_ENDPOINTS=https://downloads.example.com/hermes-companion/latest.json

# macOS signing and notarization
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Company (TEAMID)
APPLE_NOTARY_PROFILE=hermes-notary-profile

# Windows signing
HERMES_REQUIRE_SIGNED_RELEASE=1
WINDOWS_SIGN_CERT_PATH=C:\path\to\codesign.pfx
WINDOWS_SIGN_CERT_PASSWORD=
WINDOWS_SIGN_SUBJECT_NAME=
WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com
