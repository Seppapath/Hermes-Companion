# Hermes Companion reference central API environment

# Persistent JSON state for invites, node registry, and node tokens.
HERMES_COMPANION_DATA_DIR=/var/lib/hermes-companion

# Long random secret used by the operator tooling and admin-only routes.
# The service refuses the default "change-me" secret unless you explicitly opt
# into insecure local testing with HERMES_ALLOW_INSECURE_DEFAULT_ADMIN_SECRET=1.
HERMES_ADMIN_SECRET=replace-with-a-long-random-secret

# Optional backend for /v1/responses proxying.
# Recommended production option: point this at a dedicated localhost chat
# bridge that runs Hermes with no enabled tools.
# Example:
# HERMES_PROXY_RESPONSES_URL=http://127.0.0.1:8788/v1/responses
# HERMES_PROXY_BEARER_TOKEN=the-shared-secret-from-chat-bridge.env
#
# Alternate option: point this at an external OpenAI-compatible upstream such
# as https://api.openai.com/v1/responses.
#
# Leave both unset to use the reference echo response in non-production testing.
HERMES_PROXY_RESPONSES_URL=
HERMES_PROXY_BEARER_TOKEN=

# Optional local Hermes web UI backend. When set, the control plane will route
# /v1/responses through the local Hermes instance instead of the generic
# OpenAI-compatible proxy above.
#
# WARNING: this is intentionally disabled by default because a general-purpose
# Hermes web UI may expose filesystem or shell tools to enrolled nodes.
# Only enable it if you explicitly harden that Hermes instance and set
# HERMES_ALLOW_UNSAFE_WEBUI_PROXY=1.
# Example:
# HERMES_WEBUI_PROXY_URL=http://127.0.0.1:8787
# HERMES_WEBUI_PASSWORD=
# HERMES_WEBUI_WORKSPACE=/root
# HERMES_ALLOW_UNSAFE_WEBUI_PROXY=1

# Optional default model used in invites when the operator does not explicitly
# choose one.
# HERMES_DEFAULT_CHAT_MODEL=gpt-5.4-mini

# Optional local-dev escape hatch only. Do not enable in shared or production
# environments.
# HERMES_ALLOW_INSECURE_DEFAULT_ADMIN_SECRET=1
