# Hermes Companion safe chat bridge environment

# Shared secret central-api uses when proxying requests to the localhost bridge.
HERMES_CHAT_BRIDGE_TOKEN=replace-with-a-long-random-secret

# Separate Hermes home that contains a copied auth.json and a minimal config.yaml
# with an empty CLI toolset. Do not point this at a general-purpose operator
# home that has filesystem or shell tool access enabled.
HERMES_CHAT_BRIDGE_HOME=/var/lib/hermes-companion-chat/home

# Checkout of hermes-agent used by the bridge runtime.
HERMES_CHAT_BRIDGE_AGENT_DIR=/opt/hermes-companion-chat/hermes-agent

# Python interpreter used to run the bridge. Point this at an interpreter that
# can import the copied Hermes agent site-packages. On hosts where the original
# Hermes venv points into a root-only uv runtime, copy that runtime to an
# operator-readable path such as /opt/hermes-companion-chat/python-runtime.
HERMES_CHAT_BRIDGE_PYTHON=/opt/hermes-companion-chat/python-runtime/bin/python3.11

# Bind localhost only.
HERMES_CHAT_BRIDGE_HOST=127.0.0.1
HERMES_CHAT_BRIDGE_PORT=8788

# Model defaults for the bridge.
HERMES_CHAT_BRIDGE_DEFAULT_MODEL=gpt-5
HERMES_CHAT_BRIDGE_PROVIDER=openai-codex
HERMES_CHAT_BRIDGE_BASE_URL=https://chatgpt.com/backend-api/codex

# Workspace is kept deliberately inert because the bridge runs with no tools.
HERMES_CHAT_BRIDGE_WORKSPACE=/var/empty
HERMES_CHAT_BRIDGE_MAX_ITERATIONS=2
