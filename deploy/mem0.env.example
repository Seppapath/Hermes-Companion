# Mem0 OSS reference environment for central Hermes memory

# Required LLM provider key for Mem0 extraction/search.
OPENAI_API_KEY=replace-with-your-openai-api-key

# Protect the Mem0 REST server in production.
ADMIN_API_KEY=replace-with-a-long-random-secret

# Optional graph backend for relationship-aware memory.
# Pair this with Neo4j when you move into graph memory.
# NEO4J_URL=neo4j+s://your-neo4j-host
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=replace-with-your-neo4j-password

# Optional: tune any additional Mem0 OSS provider and backend configuration
# according to the upstream Mem0 deployment docs.
