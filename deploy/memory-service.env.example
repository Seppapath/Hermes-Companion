# Hermes Companion central memory service environment

# Shared API key central-api uses when calling the local memory service.
HERMES_MEMORY_API_KEY=replace-with-a-long-random-secret

# Local-only bind.
HERMES_MEMORY_BIND_HOST=127.0.0.1
HERMES_MEMORY_BIND_PORT=8040

# Durable local storage on the central server.
HERMES_MEMORY_DATA_DIR=/var/lib/hermes-companion-memory
HERMES_MEMORY_VECTOR_DIR=/var/lib/hermes-companion-memory/chroma
HERMES_MEMORY_HISTORY_DB_PATH=/var/lib/hermes-companion-memory/history.db
HERMES_MEMORY_COLLECTION_NAME=central-hermes

# Use the existing safe chat bridge as an OpenAI-compatible backend.
HERMES_MEMORY_LLM_BASE_URL=http://127.0.0.1:8788/v1
HERMES_MEMORY_LLM_API_KEY=replace-with-the-chat-bridge-token
HERMES_MEMORY_LLM_MODEL=gpt-5

# Local embeddings keep durable memory on your server without another API key.
HERMES_MEMORY_EMBEDDER_PROVIDER=fastembed
# Smaller FastEmbed model to avoid unnecessary RAM pressure on modest VPS hosts.
HERMES_MEMORY_EMBEDDER_MODEL=BAAI/bge-small-en-v1.5

# Phase A defaults to semantic transcript storage for reliability.
# Set to 1 later if you want Mem0 to perform fact extraction via the bridge.
HERMES_MEMORY_INFER=0
